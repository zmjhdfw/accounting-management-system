<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="300dp"
    android:layout_height="wrap_content"
    android:background="#FFFFFF">
    
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">
        
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="添加凭证"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_marginBottom="20dp"/>
        
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="凭证号"
            android:textSize="16sp"
            android:textColor="#666666"
            android:layout_marginBottom="8dp"/>
        
        <EditText
            android:id="@+id/voucher_number_edit"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="例如: 001"
            android:inputType="number"
            android:textSize="16sp"
            android:textColor="#000000"
            android:textColorHint="#999999"
            android:padding="12dp"
            android:background="@android:drawable/edit_text"
            android:layout_marginBottom="16dp"/>
        
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="日期"
            android:textSize="16sp"
            android:textColor="#666666"
            android:layout_marginBottom="8dp"/>
        
        <EditText
            android:id="@+id/voucher_date_edit"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="例如: 2026-04-19"
            android:textSize="16sp"
            android:textColor="#000000"
            android:textColorHint="#999999"
            android:padding="12dp"
            android:background="@android:drawable/edit_text"
            android:layout_marginBottom="16dp"/>
        
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="摘要"
            android:textSize="16sp"
            android:textColor="#666666"
            android:layout_marginBottom="8dp"/>
        
        <EditText
            android:id="@+id/voucher_summary_edit"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="例如: 收到投资款"
            android:textSize="16sp"
            android:textColor="#000000"
            android:textColorHint="#999999"
            android:padding="12dp"
            android:background="@android:drawable/edit_text"
            android:layout_marginBottom="16dp"/>
        
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="借方科目"
            android:textSize="16sp"
            android:textColor="#666666"
            android:layout_marginBottom="8dp"/>
        
        <EditText
            android:id="@+id/debit_account_edit"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="例如: 1001"
            android:inputType="number"
            android:textSize="16sp"
            android:textColor="#000000"
            android:textColorHint="#999999"
            android:padding="12dp"
            android:background="@android:drawable/edit_text"
            android:layout_marginBottom="16dp"/>
        
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="贷方科目"
            android:textSize="16sp"
            android:textColor="#666666"
            android:layout_marginBottom="8dp"/>
        
        <EditText
            android:id="@+id/credit_account_edit"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="例如: 2001"
            android:inputType="number"
            android:textSize="16sp"
            android:textColor="#000000"
            android:textColorHint="#999999"
            android:padding="12dp"
            android:background="@android:drawable/edit_text"
            android:layout_marginBottom="16dp"/>
        
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="金额"
            android:textSize="16sp"
            android:textColor="#666666"
            android:layout_marginBottom="8dp"/>
        
        <EditText
            android:id="@+id/voucher_amount_edit"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="例如: 10000.00"
            android:inputType="numberDecimal"
            android:textSize="16sp"
            android:textColor="#000000"
            android:textColorHint="#999999"
            android:padding="12dp"
            android:background="@android:drawable/edit_text"
            android:layout_marginBottom="24dp"/>
        
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            
            <Button
                android:id="@+id/cancel_button"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="取消"
                android:textSize="16sp"
                android:layout_marginEnd="8dp"/>
            
            <Button
                android:id="@+id/save_button"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="保存"
                android:textSize="16sp"/>
                
        </LinearLayout>
        
    </LinearLayout>
    
</ScrollView>
